# Environment (development/production)
FLASK_ENV=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Controller settings
CONTROLLER_HOST=0.0.0.0
CONTROLLER_PORT=8080
CONTROLLER_PUBLIC_URL=https://controller.zta.bangladesh.gov.bd

# Database
DATABASE_URL=sqlite:///../database/overlay_network.db

# Certificate paths
CA_CERT_PATH=certs/ca.crt
CA_KEY_PATH=certs/ca.key

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs/

# Master secret for identity generation (CHANGE THIS!)
MASTER_ENROLLMENT_SECRET=YOUR_MASTER_SECRET_HERE

# Bangladesh specific
BANGLADESH_TIMEZONE=Asia/Dhaka
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=16